OPENAI_API_KEY=your_api_key_here

# ── Global model fallback ─────────────────────────────────────────────────────
# Used by any agent that does not have its own MODEL_* override below.
OPENAI_MODEL=gpt-4.1-mini

# ── Per-agent model overrides ─────────────────────────────────────────────────
# Leave a value empty to fall back to OPENAI_MODEL.
# Set any agent to a different model without touching the others.
#
# Plan branch
MODEL_CHIEF_OF_STAFF=gpt-4.1       # Routing, intake, final validation — use the strongest model
MODEL_RESEARCHER=                   # Fact gathering (falls back to OPENAI_MODEL)
MODEL_WRITER=                       # Drafting (falls back to OPENAI_MODEL)
MODEL_REVIEWER=                     # QC validation (falls back to OPENAI_MODEL)
MODEL_JT=                           # Challenge/pressure-test agent (falls back to OPENAI_MODEL)
#
# Build pod
MODEL_BACKEND=                      # Core logic implementation (falls back to OPENAI_MODEL)
MODEL_FRONTEND=                     # UI/presentation layer (falls back to OPENAI_MODEL)
MODEL_QA=                           # Testing and revision control (falls back to OPENAI_MODEL)
#
# Brainstorm pod
MODEL_ADVISOR_ROUTER=               # Advisor selection (falls back to OPENAI_MODEL)
MODEL_ADVISOR=                      # Advisor synthesis (falls back to OPENAI_MODEL)
MODEL_ADVISOR_CLUSTERS=             # All 5 cluster advisors share this override

# ── Optional paths ────────────────────────────────────────────────────────────

# Optional: path to your Obsidian vault root.
# Enables CoS and Researcher to navigate CLAUDE.md files for live project context.
# Example: /Users/yourname/Documents/Obsidian/main
OBSIDIAN_VAULT_PATH=

# Optional: path to your voice/style guide file (can live anywhere, but Obsidian is ideal).
# Enables Writer to draft in your voice on every run.
# Example: /Users/yourname/Documents/Obsidian/main/00 Meta/voice.md
VOICE_FILE_PATH=

# Optional: path to the session persistence file.
# Saves objective, approved output, open questions, and latest draft across restarts.
# Default resolution: OUTPUT_DIR/session_memory.json → ~/.agent_team/session_memory.json
# SESSION_FILE=
