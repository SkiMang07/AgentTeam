OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Optional: path to your Obsidian vault root.
# Enables CoS and Researcher to navigate CLAUDE.md files for live project context.
# Example: /Users/yourname/Documents/Obsidian/main
OBSIDIAN_VAULT_PATH=

# Optional: path to your voice/style guide file (can live anywhere, but Obsidian is ideal).
# Enables Writer to draft in your voice on every run.
# Example: /Users/yourname/Documents/Obsidian/main/00 Meta/voice.md
VOICE_FILE_PATH=
